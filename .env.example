# Set at least one of these — the dropdown defaults to Gemini.
GOOGLE_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Optional: LangSmith tracing
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=bank-statement-agent
LANGSMITH_TRACING=false

# Tunables
# Categorisation batches transactions per LLM call.
# Smaller = more reliable on small models, more API calls.
# Larger = fewer calls but risk of model dropping rows past ~150.
CATEGORISE_CHUNK_SIZE=100

# How many transactions to send to the LLM contextual layer of anomaly detection.
# Rules run on the full list; only the LLM pass is sampled.
ANOMALY_SAMPLE_SIZE=50

# LLM retry on transient failures (503, 429, timeouts).
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=1.0

# Local
CHROMA_PERSIST_DIR=./.chroma
LOG_LEVEL=INFO
